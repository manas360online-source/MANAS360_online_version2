NODE_ENV=development
PORT=5001
API_PREFIX=/api
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# DATABASE_URL=postgresql://manas360:manas360@localhost:5432/manas360
DATABASE_URL="postgresql://postgres:1230@localhost:5432/manas360_db?schema=public"
REDIS_URL=redis://127.0.0.1:6379

# REDIS_ENABLED=false
# CACHE_DRIVER=memory

JWT_ACCESS_SECRET=change-access-secret
JWT_REFRESH_SECRET=change-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECURE=false
SESSION_NOTES_ENCRYPTION_KEY=change-session-notes-encryption-key

CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-haiku
CLAUDE_SONNET_MODEL=claude-3-5-sonnet-20241022

# Optional outbound email connector for local testing
EMAIL_PROVIDER=
EMAIL_WEBHOOK_URL=
EMAIL_FROM_NAME=MANAS360
EMAIL_FROM_ADDRESS=noreply@manas360.com
EMAIL_REPLY_TO=support@manas360.com

# Optional platform admin invite email customization
ADMIN_INVITE_EMAIL_SUBJECT=Your MANAS360 admin invitation
ADMIN_INVITE_LOGIN_URL=http://localhost:5173/admin-portal/login
